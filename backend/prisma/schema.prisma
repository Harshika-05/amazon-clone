// tells prisma to generate the js client we import in our code
generator client {
  provider = "prisma-client-js"
}

// db connection — reads DATABASE_URL from .env file
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(uuid()) // uuid = universally unique id, auto-generated
  name           String
  email          String    @unique // no two users can have same email
  password       String    // stored as bcrypt hash, never plaintext
  defaultAddress String?   // ? means optional/nullable
  cart           Cart?     // one-to-one: each user has max one cart
  orders         Order[]   // one-to-many: user can have many orders
  wishlist       Wishlist? // one-to-one
  reviews        Review[]  // one-to-many
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  products Product[]
}

model Product {
  id            String         @id @default(uuid())
  name          String
  description   String
  price         Float          // stored as decimal number
  stock         Int            // current inventory count
  categoryId    String
  category      Category       @relation(fields: [categoryId], references: [id]) // foreign key linking to Category
  images        ProductImage[] // one product can have multiple images
  cartItems     CartItem[]     // reverse relation — which carts have this product
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]
  reviews       Review[]
}

model ProductImage {
  id        String  @id @default(uuid())
  url       String
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model Cart {
  id      String     @id @default(uuid())
  userId  String     @unique
  user    User       @relation(fields: [userId], references: [id])
  items   CartItem[]
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1) // defaults to 1 if not specified
}

model Order {
  id                 String      @id @default(uuid())
  userId             String
  user               User        @relation(fields: [userId], references: [id])
  totalAmount        Float
  shippingAddress    String
  status             String      @default("PENDING") // can be PENDING, SHIPPED, DELIVERED, CANCELLED
  cancellationReason String?     // only filled when user cancels
  createdAt          DateTime    @default(now()) // auto-set to current timestamp
  items              OrderItem[]
}

model OrderItem {
  id              String  @id @default(uuid())
  orderId         String
  order           Order   @relation(fields: [orderId], references: [id])
  productId       String
  product         Product @relation(fields: [productId], references: [id])
  quantity        Int
  priceAtPurchase Float   // snapshot of price when ordered, so price changes later don't affect old orders
}

model Wishlist {
  id      String         @id @default(uuid())
  userId  String         @unique
  user    User           @relation(fields: [userId], references: [id])
  items   WishlistItem[]
}

model WishlistItem {
  id         String   @id @default(uuid())
  wishlistId String
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([wishlistId, productId]) // compound unique — same product can't be in wishlist twice
}

model Review {
  id        String   @id @default(uuid())
  rating    Int      // 1 to 5
  comment   String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // prisma auto-updates this on every edit

  @@unique([userId, productId]) // compound unique — one review per user per product
}

// temporary otp storage — deleted after successful verification
model OtpVerification {
  id        String   @id @default(uuid())
  email     String   @unique // one active otp per email at a time
  otp       String
  expiresAt DateTime // checked against current time to validate
  createdAt DateTime @default(now())
}
